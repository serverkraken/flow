# flow-server local dev configuration for podman/docker compose.
#
# Copy this file to `.env` and adjust as needed. The compose stack reads
# from `.env` via `env_file:` on the flow-server and litestream services.
#
# Every variable here mirrors what `httpserver.LoadConfig()` reads from the
# environment (see internal/adapter/httpserver/config.go). Defaults match the
# compose service names (dex:5556, minio:9000) so the file works out-of-box.
#
# For PRODUCTION:
#   - regenerate cookie keys (openssl rand -hex 32 for each)
#   - point FLOW_OIDC_* at the real IdP (Authentik realm)
#   - set FLOW_ALLOWED_SUBS to the real OIDC sub of each allowed user
#   - swap litestream minio for the real S3 / Hetzner Object Storage bucket

# ---- HTTP server -----------------------------------------------------------

FLOW_SERVER_ADDR=:8080
FLOW_SERVER_BASE_URL=http://localhost:8080

# ---- SQLite path inside the container -------------------------------------
# Mounted under the flow-data named volume; litestream sees the same path
# via the shared volume mount.
FLOW_SERVER_DB=/var/lib/flow/server.db

# ---- OIDC (dex inside the compose network) --------------------------------
# Inside the compose network dex is at http://dex:5556. From a browser on the
# host it's http://localhost:5556 — dex' issuer URL must be reachable from
# both sides, so dex-config.yaml uses http://localhost:5556 and the host
# resolves dex via /etc/hosts (compose adds it automatically for the
# flow-server -> dex link).
FLOW_OIDC_ISSUER=http://localhost:5556
# Browser auth-code flow (confidential client). dex's `flow-server-dev`
# client matches this — see deploy/podman/dex-config.yaml.
FLOW_OIDC_CLIENT_ID=flow-server-dev
FLOW_OIDC_CLIENT_SECRET=dev-secret
# CLI/MCP device-flow (public client, no secret). flow-server publishes this
# via /api/v1/oidc/config so CLIs don't need to know the IdP directly. dex's
# `flow-cli` static client is registered with `public: true` for this.
# Default `flow-cli` matches the dex config; only set this if you renamed the
# public client in your IdP.
FLOW_OIDC_CLI_CLIENT_ID=flow-cli

# ---- Cookie keys (REGENERATE FOR PROD) ------------------------------------
# 32 bytes hex (64 chars) each. Generate fresh with:
#   openssl rand -hex 32
# These are dev-only defaults committed in plain text — DO NOT REUSE IN PROD.
FLOW_COOKIE_HASH_KEY=6427348cbac53272ad6b2185d48713a13e3e098f202c6e19f0f1f228f3ca0337
FLOW_COOKIE_BLOCK_KEY=4b4f1f7e84b78173714ee6bd6260bcb8651e49ba386c34492f305fe432feb29d

# ---- Access control --------------------------------------------------------
# Comma-separated list of OIDC `sub` claim values allowed to use the server.
# Dex wraps static-password userID + connector-id into a protobuf and base64-
# encodes it as the JWT sub. For the soenne@local user in dex-config.yaml
# (userID=localdev, connector=local) the sub string is:
FLOW_ALLOWED_SUBS=Cghsb2NhbGRldhIFbG9jYWw
# In prod (Authentik), sub is the Authentik UID — replace with the real
# value (or read the WARN log from flow-server on first login attempt).

# ---- Notebook (optional) ---------------------------------------------------
# Empty default — /notes shows a placeholder instead of 500ing. Set to a
# kompendium notebook path on the host (mounted into the container) to
# enable read-only notes browsing.
FLOW_NOTEBOOK_ROOT=

# ---- Litestream / S3 credentials ------------------------------------------
# Picked up by the litestream service for the minio sink in litestream.yml.
# Match the MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yml.
LITESTREAM_ACCESS_KEY_ID=minio
LITESTREAM_SECRET_ACCESS_KEY=minio123
